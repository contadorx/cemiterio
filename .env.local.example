# Copie para .env.local (local) ou cadastre na Vercel. Redeploy após alterar!

# ---- Supabase (obrigatórias) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- IA (obrigatórias) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ---- WhatsApp / Evolution (obrigatórias) ----
EVOLUTION_API_URL=https://api.contatia.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=sureya

# ---- Identificação do negócio (obrigatórias) ----
SUREYA_ORG_ID=
SUREYA_WEBHOOK_SECRET=

# ---- Crons (obrigatória p/ os robôs rodarem) ----
CRON_SECRET=

# ---- Transcrição de áudio (opcional: use uma das duas) ----
GROQ_API_KEY=
OPENAI_API_KEY=

# ---- Ajustes finos (opcionais, têm padrão) ----
SUREYA_SCORE_LIMITE_AUTO=80
SUREYA_DEBOUNCE_SEGUNDOS=20

# --- NOTIFICAÇÕES NO NAVEGADOR (Web Push) ---
# Gere um par novo com:  npx web-push generate-vapid-keys
# A pública precisa aparecer nas duas variáveis (uma para o servidor, outra para o navegador).
VAPID_PUBLIC_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@zeloememoria.com.br
